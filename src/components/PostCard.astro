---
import { postUrl } from '../lib/postUrl';
import { slugify } from '../lib/slug';
import { formatShort, isoDate } from '../lib/date';
import Pill from './Pill.astro';

interface Props {
  post: {
    data: {
      title: string;
      slug: string;
      date: Date;
      excerpt?: string;
      categories: string[];
      tags: string[];
    };
  };
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const url = postUrl(post);
const cats = post.data.categories.slice(0, 3);
---
<article class:list={['card group relative', featured ? 'p-7 sm:p-9' : 'p-5 sm:p-6']}>
  <a href={url} class="absolute inset-0 z-10" aria-label={post.data.title}></a>
  <div class="flex items-center gap-3 text-xs text-[var(--fg-subtle)]">
    <time datetime={isoDate(post.data.date)} class="font-mono tracking-tight">
      {formatShort(post.data.date)}
    </time>
    {cats.length > 0 && (
      <>
        <span aria-hidden="true">&middot;</span>
        <div class="flex flex-wrap gap-1.5">
          {cats.map((c) => (
            <span class="text-[var(--fg-muted)]">{c}</span>
          ))}
        </div>
      </>
    )}
  </div>

  <h2 class:list={['mt-3 font-semibold tracking-tight text-[var(--fg)] transition-colors group-hover:text-[var(--accent-strong)]', featured ? 'text-2xl sm:text-3xl' : 'text-lg sm:text-xl']}>
    {post.data.title}
  </h2>

  {post.data.excerpt && (
    <p class:list={['mt-2 text-[var(--fg-muted)] leading-relaxed', featured ? 'text-base' : 'text-sm']}>
      {post.data.excerpt}
    </p>
  )}

  <div class="mt-4 flex flex-wrap items-center gap-1.5 relative z-20">
    {cats.map((c) => (
      <Pill href={`/category/${slugify(c)}/`} label={c} />
    ))}
    <a
      href={url}
      class="ml-auto inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-xs text-[var(--fg-subtle)] transition-colors hover:text-[var(--accent-strong)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)] group-hover:text-[var(--accent-strong)]"
      aria-label={`Read: ${post.data.title}`}
    >
      Read
      <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/>
        <path d="m13 5 7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
