---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  { src: '/logocb.png',  href: 'https://cloudblogger.eu',    label: 'CloudBlogger' },
  { src: '/logogit.png', href: 'https://passadis.github.io', label: 'GitHub' },
];
---
<BaseLayout
  title="About"
  description="Welcome — I'm Konstantinos, the creator of CloudBlogger and other projects in the Azure and AI ecosystem."
>
  <section class="mb-20 grid items-center gap-10 sm:grid-cols-[auto_1fr]">
    <div class="mx-auto sm:mx-0">
      <div class="relative h-40 w-40 sm:h-48 sm:w-48">
        <div class="absolute -inset-1 rounded-full bg-gradient-to-br from-[var(--color-aurora-1)] via-[var(--color-aurora-2)] to-[var(--color-aurora-3)] opacity-60 blur-md"></div>
        <div class="relative flex h-full w-full items-center justify-center overflow-hidden rounded-full border border-[var(--border)] bg-[var(--surface)]">
          <img
            src="/avatar.jpg"
            alt="Konstantinos Passadis"
            loading="eager"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--fg-subtle)]">About</p>
      <h1 class="mt-3 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">
        Welcome &mdash; I&rsquo;m <span class="gradient-text">Konstantinos</span>,
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-[var(--fg-muted)]">
        the creator of <a href="https://cloudblogger.eu" class="text-[var(--accent-strong)] underline decoration-[color-mix(in_oklch,var(--accent)_40%,transparent)] underline-offset-4 hover:decoration-[var(--accent)]">cloudblogger.eu</a>
        and a number of innovative projects in the Azure and AI ecosystem.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-[var(--fg-muted)]">
        This website now serves as a static archive, preserving all posts and historical
        content published before 2025.
      </p>
    </div>
  </section>

  <section class="mb-20">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--fg-subtle)]">Find me elsewhere</p>
    <ul class="mt-5 flex items-center justify-center gap-8 sm:gap-12">
      {links.map((l) => (
        <li class="shrink-0">
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={l.label}
            title={l.label}
            class="group inline-flex h-8 items-center justify-center rounded-md px-2 transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
          >
            <img
              src={l.src}
              alt={l.label}
              loading="lazy"
              decoding="async"
              class="block h-20 w-auto object-contain opacity-75 transition-opacity duration-200 group-hover:opacity-100"
            />
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mb-12">
    <figure class="card relative mx-auto max-w-3xl p-8 sm:p-12 text-center">
      <span aria-hidden="true" class="pointer-events-none absolute left-4 top-2 select-none font-display text-7xl leading-none text-[color-mix(in_oklch,var(--accent)_30%,transparent)] sm:left-6 sm:text-8xl">&ldquo;</span>
      <blockquote class="relative text-2xl font-medium leading-relaxed tracking-tight text-[var(--fg)] sm:text-3xl">
        <span class="gradient-text">&ldquo;theory loses&rdquo;</span> when it clashes with practice
      </blockquote>
      <figcaption class="relative mt-5 font-mono text-xs uppercase tracking-[0.18em] text-[var(--fg-subtle)]">
        &mdash; Linus Torvalds
      </figcaption>
    </figure>
  </section>
</BaseLayout>
